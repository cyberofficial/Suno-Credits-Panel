{
  "manifest_version": 3,
  "name": "Suno Credits Display",
  "version": "1.0.0",
  "description": "Displays your Suno AI credits in the sidebar navigation and extension popup",
  "permissions": [
    "storage",
    "cookies",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://suno.com/*",
    "https://studio-api-prod.suno.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://suno.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Suno Credits",
    "default_icon": {
      "128": "Icon.png"
    }
  },
  "icons": {
    "128": "Icon.png"
  }
}